# Copy to .env.local and fill in. (.env.local is gitignored.)
# Force-committed despite .gitignore's `.env*` rule (see README / git add -f).

# Public base URL of the site (no trailing slash).
SITE_URL=http://localhost:3000

# --- Stripe ---
# Test-mode keys for dev; live keys in production (set in Vercel, not here).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` locally, or the dashboard webhook endpoint when deployed.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Printify ---
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
# Leave unset in real use (defaults to https://api.printify.com/v1). Tests set a mock.
PRINTIFY_API_BASE=

# --- Resend (optional; absent => tracking emails are logged) ---
RESEND_API_KEY=
EMAIL_FROM=Gotham Goods <orders@your-verified-domain.com>

# --- Supabase (optional locally; REQUIRED in production) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Live finals data (cron scrape) ---
# Firecrawl key for the fallback scraper (primary source is ESPN's free JSON API).
FIRECRAWL_API_KEY=fc-xxx
# Shared secret protecting /api/cron/refresh-series. Must match the GitHub Actions
# repo secret and the Vercel env var. Generate: openssl rand -hex 24
CRON_SECRET=

# --- Meta (Facebook/Instagram) ads tracking ---
# All optional: when unset, the Pixel loader isn't rendered and CAPI no-ops, so
# the site runs exactly as before. Set these after the Meta bootstrap (see
# docs/META_ADS_SETUP.md). Get the same numeric Pixel id into BOTH vars below.
NEXT_PUBLIC_META_PIXEL_ID=        # public — baked into the browser bundle (Pixel id)
META_PIXEL_ID=                    # server — same numeric value, used by CAPI
META_CAPI_ACCESS_TOKEN=          # Conversions API token (Events Manager > dataset > Settings)
META_TEST_EVENT_CODE=            # optional — set while validating in Test Events, remove in prod
META_DOMAIN_VERIFICATION=        # facebook-domain-verification token (Business Settings > Domains)
# Leave unset in real use (defaults to https://graph.facebook.com/v21.0). Tests can override.
META_GRAPH_BASE=

# --- Claude API (zero-touch product copy: scripts/sync-products.mjs) ---
# Discovers new Printify products and writes their marketing copy into
# data/auto-products.json. Set ANTHROPIC_API_KEY in GitHub Actions secrets too.
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-6). claude-haiku-4-5 = cheaper bulk copy.
ANTHROPIC_MODEL=
