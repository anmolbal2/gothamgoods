# Offline test overrides (Layer B webhook tests).
# Force-committed despite .gitignore's `.env*` rule (see README / git add -f).
#
# NOTE: STRIPE_SECRET_KEY is intentionally NOT set here. Layer B verifies webhook
# signatures using STRIPE_WEBHOOK_SECRET (a local HMAC, no network), so it works
# with the placeholder key. Leaving STRIPE_SECRET_KEY unset means the live E2E
# (Layer A) picks up your real test key from .env.local in the same run.

SITE_URL=http://localhost:3000

# Deterministic secret: fixtures sign events with this, the route verifies with it.
STRIPE_WEBHOOK_SECRET=whsec_testsecret123

# Point Printify at the local mock server (tests/mock-printify.mjs on :4010).
PRINTIFY_API_BASE=http://localhost:4010
PRINTIFY_API_TOKEN=test-token
PRINTIFY_SHOP_ID=1

# Force the in-memory order store + logged emails during tests, even though
# .env.local has real Supabase/Resend creds (these empty values are passed to the
# dev server via playwright.config and take precedence over .env.local).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
